<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- 装饰性边框 - 顶部 -->
        <View
            android:id="@+id/decoration_top"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/border"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- 标题容器 - 手账风格卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/border"
        app:strokeWidth="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/decoration_top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 小装饰图标 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✿"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/app_name"
                android:textColor="@color/primary"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- 副标题 -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="✧ 每次解锁手机，学一个单词 ✧"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 状态卡片 - 手账页风格 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 装饰线 -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:background="@color/accent"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="单词推送已开启"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_notebook_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="生词本：0 个单词\n词库：40 个单词"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 开关卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_switch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_status">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="开启单词推送"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="在锁屏和通知栏显示单词卡片"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:checked="true" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 按钮容器 -->
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_switch">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_notebook"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/notebook"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconTint="@color/white"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_library"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="词库选择"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconTint="@color/white"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh_now"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="立即刷新"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_rotate"
            app:iconTint="@color/white"
            app:iconSize="20dp" />

    </LinearLayout>

    <!-- 说明卡片 - 手账贴纸风格 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/highlight_light"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 装饰标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✎ 使用手记"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. 开启推送后，会定期收到单词通知（像淘宝推送）\n2. 不需要app挂在后台，不占用资源\n3. 点击「认识」直接跳过\n4. 点击「不认识」加入生词本\n5. 在生词本中复习不认识的单词"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 装饰性边框 - 底部 -->
    <View
        android:id="@+id/decoration_bottom"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:layout_marginTop="16dp"
        android:background="@color/border"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_description" />

</androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
